{
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "New MQL:\n*<{{ProfileURL}}|{{First}} {{Last}} - {{Company}}>*"
      }
    },
    {
      "type": "section",
      "fields": [
        {
          "type": "mrkdwn",
          "text": "*Company Size:*\n{{Size}}"
        },
        {
          "type": "mrkdwn",
          "text": "*Company Industry:*\n{{Industry}}"
        },
        {
          "type": "mrkdwn",
          "text": "*Job Title:*\n{{Title}}"
        },
        {
          "type": "mrkdwn",
          "text": "*Email:*\n{{Email}}"
        }
      ]
    },
    {
      "type": "actions",
      "elements": [
        {
          "type": "button",
          "action_id": "open_review_modal",
          "text": {
            "type": "plain_text",
            "text": "Review",
            "emoji": true
          },
          "style": "primary",
          "value": "{{ReviewContext}}"
        }
      ]
    }
  ]
}
